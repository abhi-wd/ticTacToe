{
  "files": [
    "./src/types.ts",
    "./src/match_handler.ts",
    "./src/main.ts"
  ],
  "compilerOptions": {
    "target": "es5",
    "lib": ["es2020"],
    "typeRoots": [
      "./node_modules"
    ],
    "outFile": "./build/index.js",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
